# Copy to .env and fill in values
# On Render, set these in the dashboard or via render.yaml — do NOT commit real secrets

# --- Django core ---
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret-key

# Comma-separated hostnames (no scheme) — include your .onrender.com subdomain
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.onrender.com

# --- CORS ---
# Comma-separated origins (with scheme) — your Vercel frontend URL
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Database (Render PostgreSQL free tier) ---
POSTGRES_DB=versioning_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=your-render-db-host.render.com
POSTGRES_PORT=5432

# --- Cache (Redis) ---
# Leave blank or remove if not using Redis on free tier
REDIS_URL=redis://127.0.0.1:6379/1
